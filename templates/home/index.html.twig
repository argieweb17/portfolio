{% extends 'base.html.twig' %}

{% block title %}Portfolio{% endblock %}

{% block javascripts %}{% endblock %}

{% block stylesheets %}
	<style>
		@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&display=swap');

		:root {
			--left-bg: #d3d3d3;
			--right-bg: #050505;
			--left-text: #111111;
			--muted-text: #7a7a7a;
			--card-bg: #bcbcbc;
			--pill-bg: #f2f2f2;
		}

		* {
			box-sizing: border-box;
		}

		html {
			scroll-behavior: smooth;
		}

		body {
			margin: 0;
			min-height: 100vh;
			overflow-x: hidden;
			font-family: 'Space Grotesk', sans-serif;
			background: var(--right-bg);
			color: #ffffff;
		}

		.portfolio-hero {
			min-height: 100vh;
			display: grid;
			grid-template-columns: minmax(360px, 53%) 1fr;
			overflow: visible;
		}

		.intro-pane {
			background: var(--left-bg);
			color: var(--left-text);
			padding: 54px 82px 70px 64px;
			display: flex;
			flex-direction: column;
			position: relative;
			z-index: 1;
		}

		.brand-mark {
			width: clamp(180px, 22vw, 300px);
			max-width: 100%;
			height: auto;
			display: block;
		}

		.intro-copy {
			margin-top: auto;
			margin-bottom: 18vh;
			max-width: 460px;
			opacity: 0;
			animation: popUpLeft 740ms cubic-bezier(0.22, 1, 0.36, 1) 120ms forwards;
			will-change: transform, opacity;
		}

		.intro-copy .lead {
			margin: 0;
			font-size: clamp(1.8rem, 2.3vw, 2.9rem);
			font-weight: 700;
			line-height: 1.1;
		}

		.intro-copy h1 {
			margin: 12px 0 8px;
			font-size: clamp(2.4rem, 4.2vw, 5rem);
			line-height: 1;
			letter-spacing: -0.04em;
			font-weight: 800;
		}

		.intro-copy .role {
			margin: 0;
			font-size: clamp(1rem, 1.25vw, 1.45rem);
			font-weight: 700;
			color: var(--muted-text);
		}

		.social-links {
			margin-top: 44px;
			display: flex;
			gap: 14px;
			opacity: 0;
			animation: popUpLeft 680ms cubic-bezier(0.22, 1, 0.36, 1) 420ms forwards;
			will-change: transform, opacity;
		}

		@keyframes popUpLeft {
			0% {
				opacity: 0;
				transform: translate3d(-28px, 40px, 0) scale(0.96);
			}

			100% {
				opacity: 1;
				transform: translate3d(0, 0, 0) scale(1);
			}
		}

		@keyframes popUpRight {
			0% {
				opacity: 0;
				transform: translate3d(34px, 46px, 0) scale(0.95);
			}

			100% {
				opacity: 1;
				transform: translate3d(0, 0, 0) scale(1);
			}
		}

		.social-links a {
			width: 54px;
			height: 54px;
			display: grid;
			place-items: center;
			text-decoration: none;
			color: #111111;
			background: #c8c8c8;
			border-radius: 4px;
			font-size: 2rem;
			font-weight: 600;
			box-shadow: 0 2px 0 rgba(17, 17, 17, 0.26);
			transition: transform 140ms ease, background-color 140ms ease;
		}

		.social-links a svg {
			width: 26px;
			height: 26px;
			display: block;
			fill: #111111;
		}

		.social-links .icon-at {
			line-height: 1;
			transform: translateY(-1px);
		}

		.social-links .icon-fb {
			width: 26px;
			height: 26px;
			display: grid;
			place-items: center;
			border-radius: 50%;
			background: #111111;
			color: #ffffff;
			font-size: 1.05rem;
			font-weight: 800;
			line-height: 1;
			font-family: Arial, sans-serif;
		}

		.social-links a:hover {
			transform: translateY(-2px);
			background: #b0b0b0;
		}

		.visual-pane {
			background: var(--right-bg);
			position: relative;
			padding: 34px 56px 0;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
			align-items: center;
			z-index: 2;
		}

		.visual-pane::before {
			content: '';
			position: absolute;
			top: 0;
			bottom: 0;
			left: -72px;
			width: 320px;
			background: var(--right-bg);
			transform: skewX(-11deg);
			transform-origin: right top;
			pointer-events: none;
		}

		.top-nav {
			width: 100%;
			position: relative;
			z-index: 5;
			display: flex;
			justify-content: flex-end;
			align-items: center;
			gap: 38px;
			font-size: 0.95rem;
			font-weight: 600;
			padding-right: 8px;
		}

		.top-nav a {
			text-decoration: none;
			color: rgba(255, 255, 255, 0.92);
			transition: opacity 140ms ease;
		}

		.top-nav a:hover {
			opacity: 0.7;
		}

		.top-nav .contact-link {
			color: #111111;
			background: var(--pill-bg);
			border-radius: 999px;
			padding: 12px 22px;
			font-size: 0.82rem;
			font-weight: 800;
			letter-spacing: 0.02em;
		}

		.portrait {
			position: relative;
			z-index: 2;
			width: min(680px, 92%);
			max-height: 84vh;
			margin-top: auto;
			object-fit: contain;
			object-position: center bottom;
			opacity: 0;
			animation: popUpRight 880ms cubic-bezier(0.22, 1, 0.36, 1) 260ms forwards;
			will-change: transform, opacity;
			filter: drop-shadow(0 20px 44px rgba(0, 0, 0, 0.45));
		}

		.about-section {
			background: #dbdbdb;
			color: #111111;
			padding: 110px 24px 120px;
			scroll-margin-top: 16px;
		}

		.about-wrap {
			max-width: 920px;
			margin: 0 auto;
			text-align: center;
		}

		.about-title {
			display: inline-block;
			padding: 18px 46px;
			border: 4px solid #111111;
			font-size: clamp(1.2rem, 1.9vw, 1.65rem);
			font-weight: 800;
			letter-spacing: 0.34em;
			text-transform: uppercase;
		}

		.about-intro {
			margin: 38px auto 26px;
			max-width: 740px;
			font-size: 0.92rem;
			line-height: 1.72;
			color: #3f3f3f;
		}

		.about-explore {
			display: inline-block;
			position: relative;
			padding: 0 22px;
			font-size: 0.7rem;
			font-weight: 700;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: #1f1f1f;
		}

		.about-explore::before,
		.about-explore::after {
			content: '';
			position: absolute;
			top: 50%;
			width: 2px;
			height: 20px;
			background: #111111;
			transform: translateY(-50%);
		}

		.about-explore::before {
			left: 0;
		}

		.about-explore::after {
			right: 0;
		}

		.about-divider {
			margin: 44px auto 62px;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 14px;
			font-size: 0.92rem;
			font-weight: 700;
			letter-spacing: 0.16em;
		}

		.about-divider::before,
		.about-divider::after {
			content: '';
			width: 42px;
			height: 2px;
			background: #111111;
		}

		.about-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 58px 74px;
			text-align: left;
		}

		.about-item {
			max-width: 360px;
			margin: 0 auto;
			position: relative;
			padding-left: 20px;
		}

		.about-item::before {
			content: '';
			position: absolute;
			left: 0;
			top: 8px;
			width: 8px;
			height: 8px;
			background: #b3b3b3;
			transform: rotate(45deg);
		}

		.about-item h3 {
			margin: 0 0 10px;
			font-size: 1.34rem;
			font-weight: 800;
			letter-spacing: 0.18em;
			text-transform: uppercase;
		}

		.about-item p {
			margin: 0;
			font-size: 0.88rem;
			line-height: 1.7;
			color: #4f4f4f;
		}

		.about-item.about-item-center {
			grid-column: 1 / -1;
		}

		.about-divider.about-divider-bottom {
			margin: 64px auto 0;
		}

		.skills-section {
			background: #d9d9d9;
			color: #111111;
			padding: 38px 24px 110px;
			scroll-margin-top: 16px;
		}

		.skills-wrap {
			max-width: 760px;
			margin: 0 auto;
		}

		.skills-title {
			margin: 0 auto;
			display: block;
			width: fit-content;
			padding: 10px 48px;
			border: 3px solid #111111;
			font-size: 0.9rem;
			font-weight: 800;
			letter-spacing: 0.52em;
			text-transform: uppercase;
		}

		.skills-block {
			margin-top: 52px;
		}

		.skills-label {
			margin: 0 0 26px;
			font-size: 0.82rem;
			font-weight: 700;
			letter-spacing: 0.28em;
			text-transform: uppercase;
		}

		.skills-grid {
			display: grid;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 28px 18px;
		}

		.skill-card {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 10px;
			text-align: center;
		}

		.skill-card img {
			width: 42px;
			height: 42px;
			object-fit: contain;
		}

		.skill-card span {
			font-size: 0.62rem;
			font-weight: 600;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: #2a2a2a;
		}

		.contact-section {
			background: #d9d9d9;
			color: #111111;
			padding: 34px 24px 120px;
			scroll-margin-top: 16px;
		}

		.contact-wrap {
			max-width: 820px;
			margin: 0 auto;
			text-align: center;
		}

		.contact-title {
			margin: 0 auto;
			display: block;
			width: fit-content;
			padding: 12px 56px;
			border: 5px solid #111111;
			font-size: 1.02rem;
			font-weight: 800;
			letter-spacing: 0.52em;
			text-transform: uppercase;
		}

		.contact-intro {
			margin: 34px auto 18px;
			max-width: 580px;
			font-size: 0.78rem;
			line-height: 1.75;
			color: #2f2f2f;
		}

		.contact-divider {
			margin: 0 auto;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 12px;
			font-size: 0.92rem;
			font-weight: 700;
			letter-spacing: 0.16em;
		}

		.contact-divider::before,
		.contact-divider::after {
			content: '';
			width: 34px;
			height: 2px;
			background: #111111;
		}

		.contact-form {
			margin: 64px auto 0;
			max-width: 690px;
			text-align: left;
		}

		.contact-field {
			margin-bottom: 32px;
			border-left: 4px solid #111111;
			border-bottom: 4px solid #111111;
			padding: 10px 10px 8px;
		}

		.contact-field input,
		.contact-field textarea {
			width: 100%;
			border: 0;
			outline: 0;
			padding: 0;
			background: transparent;
			font-family: 'Space Grotesk', sans-serif;
			font-size: 0.72rem;
			font-weight: 600;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: #111111;
		}

		.contact-field input::placeholder,
		.contact-field textarea::placeholder {
			color: #777777;
			opacity: 1;
		}

		.contact-field textarea {
			min-height: 88px;
			resize: vertical;
		}

		.contact-field.contact-field-message {
			margin-top: 38px;
			padding-top: 12px;
			padding-bottom: 12px;
		}

		.contact-submit {
			margin: 8px auto 0;
			display: block;
			position: relative;
			padding: 0 34px;
			border: 0;
			background: transparent;
			font-family: 'Space Grotesk', sans-serif;
			font-size: 0.82rem;
			font-weight: 800;
			letter-spacing: 0.24em;
			text-transform: uppercase;
			color: #111111;
			cursor: pointer;
		}

		.contact-submit::before,
		.contact-submit::after {
			content: '';
			position: absolute;
			top: 50%;
			width: 2px;
			height: 28px;
			background: #111111;
			transform: translateY(-50%);
		}

		.contact-submit::before {
			left: 0;
		}

		.contact-submit::after {
			right: 0;
		}

		@media (max-width: 1080px) {
			.portfolio-hero {
				grid-template-columns: 1fr;
			}

			.intro-pane {
				padding: 34px 24px 30px;
			}

			.intro-copy {
				margin: 56px 0 10px;
			}

			.visual-pane {
				padding: 26px 18px 0;
			}

			.visual-pane::before {
				display: none;
			}

			.top-nav {
				justify-content: center;
				gap: 22px;
				flex-wrap: wrap;
				font-size: 0.88rem;
			}

			.portrait {
				width: min(560px, 96%);
			}

			.about-section {
				padding-top: 82px;
				padding-bottom: 90px;
			}

			.about-grid {
				gap: 44px 30px;
			}

			.skills-section {
				padding-top: 30px;
				padding-bottom: 84px;
			}

			.contact-section {
				padding-top: 28px;
				padding-bottom: 92px;
			}

			.contact-form {
				max-width: 640px;
			}
		}

		@media (max-width: 640px) {
			.intro-copy h1 {
				margin-top: 8px;
			}

			.top-nav {
				gap: 14px;
			}

			.top-nav .contact-link {
				padding: 10px 18px;
			}

			.social-links {
				margin-top: 28px;
			}

			.about-title {
				padding: 14px 26px;
				letter-spacing: 0.2em;
			}

			.about-intro {
				font-size: 0.86rem;
			}

			.about-grid {
				grid-template-columns: 1fr;
				gap: 36px;
			}

			.about-item,
			.about-item.about-item-center {
				grid-column: auto;
			}

			.skills-title {
				padding: 10px 30px;
				letter-spacing: 0.28em;
			}

			.skills-block {
				margin-top: 40px;
			}

			.skills-label {
				font-size: 0.72rem;
				letter-spacing: 0.2em;
			}

			.skills-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 24px 16px;
			}

			.contact-title {
				padding: 10px 28px;
				font-size: 0.92rem;
				letter-spacing: 0.32em;
				border-width: 4px;
			}

			.contact-intro {
				font-size: 0.74rem;
			}

			.contact-form {
				margin-top: 44px;
			}

			.contact-field {
				margin-bottom: 24px;
				border-left-width: 3px;
				border-bottom-width: 3px;
			}

			.contact-field input,
			.contact-field textarea {
				font-size: 0.66rem;
			}

			.contact-field.contact-field-message {
				margin-top: 28px;
			}

			.contact-submit {
				font-size: 0.74rem;
				letter-spacing: 0.18em;
				padding: 0 26px;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.intro-copy,
			.social-links,
			.portrait {
				animation: none;
				opacity: 1;
			}
		}
	</style>
{% endblock %}

{% block body %}
	<main class="portfolio-hero">
		<section class="intro-pane">
			<img class="brand-mark" src="{{ asset('images/app-logo.svg') }}?v=20260412" alt="APP logo" loading="eager" decoding="async">

			<div class="intro-copy">
				<p class="lead">Hi, I am</p>
				<h1>Argie Pair Pagbunocan</h1>
				<p class="role">Full Stack Web Developer | Graphic Desinger</p>

				<div class="social-links">
					<a href="mailto:apagbunocan@gmail.com" aria-label="Send email">
						<span class="icon-at">@</span>
					</a>
					<a href="https://github.com" target="_blank" rel="noreferrer" aria-label="GitHub">
						<svg viewBox="0 0 16 16" aria-hidden="true">
							<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59c.4.07.55-.17.55-.38c0-.19-.01-.82-.01-1.49c-2.01.37-2.53-.49-2.69-.94c-.09-.23-.48-.94-.82-1.13c-.28-.15-.68-.52-.01-.53c.63-.01 1.08.58 1.23.82c.72 1.21 1.87.87 2.33.66c.07-.52.28-.87.5-1.07c-1.78-.2-3.64-.89-3.64-3.95c0-.87.31-1.59.82-2.15c-.08-.2-.36-1.02.08-2.12c0 0 .67-.21 2.2.82c.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82c.44 1.1.16 1.92.08 2.12c.51.56.82 1.27.82 2.15c0 3.07-1.87 3.75-3.65 3.95c.29.25.54.73.54 1.48c0 1.07-.01 1.93-.01 2.2c0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
						</svg>
					</a>
					<a href="https://linkedin.com" target="_blank" rel="noreferrer" aria-label="LinkedIn">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="11" />
							<path fill="#ffffff" d="M8.85 10.04h2.06v6.28H8.85v-6.28Zm1.03-3.22a1.2 1.2 0 1 1 0 2.4a1.2 1.2 0 0 1 0-2.4Zm2.31 3.22h1.98v.86h.03c.28-.53.95-1.08 1.95-1.08c2.08 0 2.47 1.37 2.47 3.15v3.35h-2.07v-2.97c0-.71-.01-1.62-.99-1.62c-.99 0-1.14.77-1.14 1.57v3.02h-2.07v-6.28Z"/>
						</svg>
					</a>
					<a href="https://www.facebook.com/argiepairpagbunocan.17" target="_blank" rel="noreferrer" aria-label="Facebook">
						<span class="icon-fb" aria-hidden="true">f</span>
					</a>
				</div>
			</div>
		</section>

		<section class="visual-pane">
			<nav class="top-nav" aria-label="Primary">
				<a id="about-link" href="#about">About me</a>
				<a href="#skills">Skills</a>
				<a href="#portfolio">Portfolio</a>
				<a href="#contact" class="contact-link">CONTACT ME</a>
			</nav>

			<img class="portrait" src="{{ asset('images/1321 (1).png') }}" alt="Portrait photo">
		</section>
	</main>

	<section id="about" class="about-section">
		<div class="about-wrap">
			<h2 class="about-title">About Me</h2>
			<p class="about-intro">
				I design and build clean, functional web experiences from concept to deployment.
				My focus is combining strong UI structure with practical full-stack implementation.
			</p>
			<div class="about-explore">Explore</div>
			<div class="about-divider">W</div>

			<div class="about-grid">
				<article class="about-item">
					<h3>Design</h3>
					<p>
						I craft thoughtful interfaces based on project goals, user needs, and clear visual hierarchy.
					</p>
				</article>

				<article class="about-item">
					<h3>Development</h3>
					<p>
						I build responsive front-end and robust back-end features with clean, maintainable code.
					</p>
				</article>

				<article class="about-item about-item-center">
					<h3>Maintenance</h3>
					<p>
						I improve performance, fix issues quickly, and keep projects stable after deployment.
					</p>
				</article>
			</div>

			<div class="about-divider about-divider-bottom">W</div>
		</div>
	</section>

	<section id="skills" class="skills-section">
		<div class="skills-wrap">
			<h2 class="skills-title">Skills</h2>

			<div class="skills-block">
				<h3 class="skills-label">Using now:</h3>
				<div class="skills-grid">
					<article class="skill-card">
						<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" alt="HTML5" loading="lazy" decoding="async">
						<span>HTML5</span>
					</article>
					<article class="skill-card">
						<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" alt="CSS3" loading="lazy" decoding="async">
						<span>CSS3</span>
					</article>
					<article class="skill-card">
						<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sass/sass-original.svg" alt="Sass" loading="lazy" decoding="async">
