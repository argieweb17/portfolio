{% extends 'base.html.twig' %}

{% block title %}Portfolio{% endblock %}

{% block stylesheets %}
	<style>
		@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&display=swap');

		:root {
			--left-bg: #d3d3d3;
			--right-bg: #050505;
			--left-text: #111111;
			--muted-text: #7a7a7a;
			--card-bg: #bcbcbc;
			--pill-bg: #f2f2f2;
		}

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			min-height: 100vh;
			font-family: 'Space Grotesk', sans-serif;
			background: var(--right-bg);
			color: #ffffff;
		}

		.portfolio-hero {
			min-height: 100vh;
			display: grid;
			grid-template-columns: minmax(360px, 53%) 1fr;
			overflow: hidden;
		}

		.intro-pane {
			background: var(--left-bg);
			color: var(--left-text);
			padding: 54px 82px 70px 64px;
			display: flex;
			flex-direction: column;
			position: relative;
			z-index: 1;
		}

		.brand-mark {
			font-size: 1.95rem;
			font-weight: 800;
			letter-spacing: -0.08em;
			width: fit-content;
			transform: skewX(-10deg);
			border-bottom: 3px solid #111111;
			padding-bottom: 2px;
		}

		.intro-copy {
			margin-top: auto;
			margin-bottom: 18vh;
			max-width: 460px;
			opacity: 0;
			animation: popUpLeft 740ms cubic-bezier(0.22, 1, 0.36, 1) 120ms forwards;
			will-change: transform, opacity;
		}

		.intro-copy .lead {
			margin: 0;
			font-size: clamp(1.8rem, 2.3vw, 2.9rem);
			font-weight: 700;
			line-height: 1.1;
		}

		.intro-copy h1 {
			margin: 12px 0 8px;
			font-size: clamp(2.4rem, 4.2vw, 5rem);
			line-height: 1;
			letter-spacing: -0.04em;
			font-weight: 800;
		}

		.intro-copy .role {
			margin: 0;
			font-size: clamp(1rem, 1.25vw, 1.45rem);
			font-weight: 700;
			color: var(--muted-text);
		}

		.social-links {
			margin-top: 44px;
			display: flex;
			gap: 14px;
			opacity: 0;
			animation: popUpLeft 680ms cubic-bezier(0.22, 1, 0.36, 1) 420ms forwards;
			will-change: transform, opacity;
		}

		@keyframes popUpLeft {
			0% {
				opacity: 0;
				transform: translate3d(-28px, 40px, 0) scale(0.96);
			}

			100% {
				opacity: 1;
				transform: translate3d(0, 0, 0) scale(1);
			}
		}

		@keyframes popUpRight {
			0% {
				opacity: 0;
				transform: translate3d(34px, 46px, 0) scale(0.95);
			}

			100% {
				opacity: 1;
				transform: translate3d(0, 0, 0) scale(1);
			}
		}

		.social-links a {
			width: 54px;
			height: 54px;
			display: grid;
			place-items: center;
			text-decoration: none;
			color: #111111;
			background: #c8c8c8;
			border-radius: 4px;
			font-size: 2rem;
			font-weight: 600;
			box-shadow: 0 2px 0 rgba(17, 17, 17, 0.26);
			transition: transform 140ms ease, background-color 140ms ease;
		}

		.social-links a svg {
			width: 26px;
			height: 26px;
			display: block;
			fill: #111111;
		}

		.social-links .icon-at {
			line-height: 1;
			transform: translateY(-1px);
		}

		.social-links .icon-fb {
			width: 26px;
			height: 26px;
			display: grid;
			place-items: center;
			border-radius: 50%;
			background: #111111;
			color: #ffffff;
			font-size: 1.05rem;
			font-weight: 800;
			line-height: 1;
			font-family: Arial, sans-serif;
		}

		.social-links a:hover {
			transform: translateY(-2px);
			background: #b0b0b0;
		}

		.visual-pane {
			background: var(--right-bg);
			position: relative;
			padding: 34px 56px 0;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
			align-items: center;
			z-index: 2;
		}

		.visual-pane::before {
			content: '';
			position: absolute;
			top: 0;
			bottom: 0;
			left: -72px;
			width: 320px;
			background: var(--right-bg);
			transform: skewX(-11deg);
			transform-origin: right top;
		}

		.top-nav {
			width: 100%;
			position: relative;
			z-index: 2;
			display: flex;
			justify-content: flex-end;
			align-items: center;
			gap: 38px;
			font-size: 0.95rem;
			font-weight: 600;
			padding-right: 8px;
		}

		.top-nav a {
			text-decoration: none;
			color: rgba(255, 255, 255, 0.92);
			transition: opacity 140ms ease;
		}

		.top-nav a:hover {
			opacity: 0.7;
		}

		.top-nav .contact-link {
			color: #111111;
			background: var(--pill-bg);
			border-radius: 999px;
			padding: 12px 22px;
			font-size: 0.82rem;
			font-weight: 800;
			letter-spacing: 0.02em;
		}

		.portrait {
			position: relative;
			z-index: 2;
			width: min(680px, 92%);
			max-height: 84vh;
			margin-top: auto;
			object-fit: contain;
			object-position: center bottom;
			opacity: 0;
			animation: popUpRight 880ms cubic-bezier(0.22, 1, 0.36, 1) 260ms forwards;
			will-change: transform, opacity;
			filter: drop-shadow(0 20px 44px rgba(0, 0, 0, 0.45));
		}

		@media (max-width: 1080px) {
			.portfolio-hero {
				grid-template-columns: 1fr;
			}

			.intro-pane {
				padding: 34px 24px 30px;
			}

			.intro-copy {
				margin: 56px 0 10px;
			}

			.visual-pane {
				padding: 26px 18px 0;
			}

			.visual-pane::before {
				display: none;
			}

			.top-nav {
				justify-content: center;
				gap: 22px;
				flex-wrap: wrap;
				font-size: 0.88rem;
			}

			.portrait {
				width: min(560px, 96%);
			}
		}

		@media (max-width: 640px) {
			.intro-copy h1 {
				margin-top: 8px;
			}

			.top-nav {
				gap: 14px;
			}

			.top-nav .contact-link {
				padding: 10px 18px;
			}

			.social-links {
				margin-top: 28px;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.intro-copy,
			.social-links,
			.portrait {
				animation: none;
				opacity: 1;
			}
		}
	</style>
{% endblock %}

