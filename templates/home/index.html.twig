	<section id="contact" class="contact-section">
		<div class="contact-wrap">
			<h2 class="contact-title">Contact</h2>
			<p class="contact-intro">
				Nulla in velit a metus rhoncus tempus. Nulla congue nulla vel sem varius finibus. Sed ornare sit amet lorem
				sed viverra. In vel urna quis libero viverra facilisis ut ac est.
			</p>
			<div class="contact-divider">W</div>

			<form class="contact-form" action="#" method="post">
				<div class="contact-field">
					<input type="text" name="name" placeholder="Enter your name*" required>
				</div>

				<div class="contact-field">
					<input type="email" name="email" placeholder="Enter your email*" required>
				</div>

				<div class="contact-field">
					<input type="tel" name="phone" placeholder="Phone number">
				</div>

				<div class="contact-field contact-field-message">
					<textarea name="message" placeholder="Your message*" required></textarea>
				</div>

				<button class="contact-submit" type="submit">Submit</button>
			</form>
		</div>
	</section>

	<script>
		document.addEventListener('DOMContentLoaded', function () {
			const aboutLink = document.getElementById('about-link');
			const aboutSection = document.getElementById('about');

			if (!aboutLink || !aboutSection) {
				return;
			}

			aboutLink.addEventListener('click', function (event) {
				event.preventDefault();
				aboutSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
				history.replaceState(null, '', '#about');
			});

			if (window.location.hash === '#about') {
				requestAnimationFrame(function () {
					aboutSection.scrollIntoView({ behavior: 'auto', block: 'start' });
				});
			}
		});
	</script>
